{
  "version": 2,
  "builds": [
    { "src": "**/*.html", "use": "@vercel/static" },
    { "src": "api/proxy/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/proxy", "dest": "/api/proxy/index.js" },
    {
      "src": "/(.+\\.html)",
      "dest": "/$1",
      "headers": {
        "Content-Type": "text/html; charset=utf-8",
        "Cache-Control": "no-cache, no-store, must-revalidate",
        "X-Content-Type-Options": "nosniff"
      }
    },
    { "src": "/otherside-native-attack", "dest": "/otherside-native-attack.html" },
    { "src": "/otherside-native-attack.html", "dest": "/otherside-native-attack.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
